#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo "Running pre-commit checks..."

echo -n "Checking formatting... "
if ! cargo fmt --check > /dev/null 2>&1; then
    echo -e "${RED}FAILED${NC}"
    echo "Run 'cargo fmt' to fix formatting issues."
    exit 1
fi
echo -e "${GREEN}OK${NC}"

echo -n "Running clippy... "
if ! cargo clippy --all-targets --all-features -- -D warnings > /dev/null 2>&1; then
    echo -e "${RED}FAILED${NC}"
    echo "Run 'cargo clippy --all-targets' to see lint warnings."
    exit 1
fi
echo -e "${GREEN}OK${NC}"

echo -n "Checking Biome (frontend)... "
if ! biome check frontend/ > /dev/null 2>&1; then
    echo -e "${RED}FAILED${NC}"
    echo "Run 'biome check --write frontend/' to fix issues."
    exit 1
fi
echo -e "${GREEN}OK${NC}"

echo -e "${GREEN}All pre-commit checks passed!${NC}"

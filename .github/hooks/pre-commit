#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

# Detect nix and set up the run wrapper accordingly
if command -v nix &> /dev/null; then
    run() { nix develop --command "$@"; }
    prefix="nix develop --command"
else
    run() { "$@"; }
    prefix=""
fi

echo "Running pre-commit checks..."

echo -n "Checking formatting... "
output=$(run cargo fmt --check 2>&1) || {
    echo -e "${RED}FAILED${NC}"
    echo "$output"
    echo ""
    echo "To fix, run:"
    echo "  ${prefix:+$prefix }cargo fmt"
    echo ""
    echo "To see errors again, run:"
    echo "  ${prefix:+$prefix }cargo fmt --check"
    exit 1
}
echo -e "${GREEN}OK${NC}"

echo -n "Running clippy... "
output=$(run cargo clippy --all-targets --all-features -- -D warnings 2>&1) || {
    echo -e "${RED}FAILED${NC}"
    echo "$output"
    echo ""
    echo "To see lint warnings, run:"
    echo "  ${prefix:+$prefix }cargo clippy --all-targets --all-features -- -D warnings"
    exit 1
}
echo -e "${GREEN}OK${NC}"

echo -n "Checking Biome (frontend)... "
output=$(run biome check frontend/ 2>&1) || {
    echo -e "${RED}FAILED${NC}"
    echo "$output"
    echo ""
    echo "To fix, run:"
    echo "  ${prefix:+$prefix }biome check --write frontend/"
    echo ""
    echo "To see errors again, run:"
    echo "  ${prefix:+$prefix }biome check frontend/"
    exit 1
}
echo -e "${GREEN}OK${NC}"

if git diff --cached --name-only | grep -q '^mobile/'; then
    # Detect the specific reason a Gradle task can't run
    gradle_skip_reason() {
        local output="$1"
        if echo "$output" | grep -q 'JAVA_HOME is not set'; then
            echo "JAVA_HOME not set"
        elif echo "$output" | grep -q 'SDK location not found'; then
            echo "ANDROID_HOME not set"
        elif echo "$output" | grep -q 'could not resolve plugin artifact\|was not found in any of the following sources'; then
            echo "Gradle plugins not available (check network)"
        else
            return 1
        fi
    }

    echo -n "Checking Kotlin formatting (mobile)... "
    if output=$(cd mobile && ./gradlew spotlessCheck --console=plain --no-problems-report --no-daemon 2>&1); then
        echo -e "${GREEN}OK${NC}"
    elif reason=$(gradle_skip_reason "$output"); then
        echo -e "${RED}SKIPPED${NC} ($reason)"
    else
        echo -e "${RED}FAILED${NC}"
        echo "$output"
        echo ""
        echo "To fix, run:"
        echo "  cd mobile && ./gradlew spotlessApply"
        exit 1
    fi

    echo -n "Running detekt (mobile)... "
    if output=$(cd mobile && ./gradlew detekt --console=plain --no-problems-report --no-daemon 2>&1); then
        echo -e "${GREEN}OK${NC}"
    elif reason=$(gradle_skip_reason "$output"); then
        echo -e "${RED}SKIPPED${NC} ($reason)"
    else
        echo -e "${RED}FAILED${NC}"
        echo "$output"
        echo ""
        echo "To see errors again, run:"
        echo "  cd mobile && ./gradlew detekt --console=plain --no-problems-report"
        exit 1
    fi

    echo -n "Compiling Kotlin (mobile)... "
    if output=$(cd mobile && ./gradlew compileDebugKotlin --console=plain --no-problems-report --no-daemon 2>&1); then
        echo -e "${GREEN}OK${NC}"
    elif reason=$(gradle_skip_reason "$output"); then
        echo -e "${RED}SKIPPED${NC} ($reason)"
    else
        echo -e "${RED}FAILED${NC}"
        echo "$output"
        echo ""
        echo "To see errors again, run:"
        echo "  cd mobile && ./gradlew compileDebugKotlin --console=plain --no-problems-report"
        exit 1
    fi
fi

echo -e "${GREEN}All pre-commit checks passed!${NC}"
